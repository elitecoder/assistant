<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  OPT-IN daemon. install.sh copies this plist (PLIST_SKIP: copy-but-not-load) but
  loads it ONLY from step 8, and only behind an explicit interactive opt-in — a
  non-interactive `install.sh --apply` (self-update) never starts it.

  Paths use the __HOME__/__REPO__/__PYTHON__/__PATH__ tokens that install.sh
  substitutes with this box's real values, so this daemon works on ANY box and
  arch, not just one hardcoded user. HOME is intentionally NOT set in the
  environment (launchd provides the user's HOME); the tokens only fill the
  program/log paths.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.assistant.machine-config-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>__REPO__/bin/machine-config-sync.py</string>
    </array>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.assistant/machine-config-sync.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.assistant/machine-config-sync.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__PATH__</string>
    </dict>
</dict>
</plist>
