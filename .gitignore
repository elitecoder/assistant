# Runtime caches and state — these are derived/regenerated and should never be committed.
__pycache__/
*.pyc
*.pyo

# Lessons are agent-curated runtime memory. They live at ~/.assistant/lessons/
# and grow per-install; nothing about them belongs in version control. (Repo
# previously tracked lessons/ before the 2026-05-23 migration.)
lessons/

# Eval run artifacts
evals/*/last-run.json
evals/*/__pycache__/

# Editor/OS noise
.DS_Store
*.swp
.idea/
.vscode/

# pytest coverage output
.coverage
.coverage.*
htmlcov/

# uv ephemeral test-runner artifacts (`uv run --with pytest ...`). The comms
# venv was removed with the Telegram/Discord teardown; uv is now the de-facto
# way to run the suite. Neither file is a build input we want under version
# control — both are regenerated on demand.
uv.lock
src/*.egg-info/

# Local-only overrides (you can drop a settings.local.json here later)
**/local.json
**/*.local

# Observer eval scratch files
evals/observer/fixtures/*/ctx.runtime.json
evals/observer/fixtures/*/verdicts.jsonl
evals/observer/last-run.log

evals/observer/last-run.log

# slack-reactor Node deps (reinstalled by spawn-slack-reactor.sh)
slack-reactor/node_modules/
slack-reactor/package-lock.json

# mem0 semantic-memory venv (Python 3.12; mem0ai + chroma + boto3 + fastembed).
# Rebuilt by bin/tools/install-mem0-venv.sh — 380MB of deps, never committed.
# mem0_backend.ensure_venv() re-execs into it; absent it, tools fall back to
# the dependency-free local-jsonl store.
.venv-mem0/
